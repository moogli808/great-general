---
const links = [
  { label: 'General Contracting',    href: '/services/general-contracting' },
  { label: 'Interior Remodeling',    href: '/services/interior-remodeling' },
  { label: 'Metal Fabrication',      href: '/services/metal-fabrication' },
  { label: 'Quonset Hut Construction', href: '/services/quonset-hut-hawaii' },
];

const { pathname } = Astro.url;
---

<header class="site-header">
  <div class="container header-inner">
    <a href="/" class="site-logo" aria-label="Great General LLC — Home">
      <span class="logo-mark">GG</span>
      <span class="logo-text">Great General<span class="logo-llc"> LLC</span></span>
    </a>

    <nav class="primary-nav" id="primary-nav" aria-label="Primary navigation">
      <div class="nav-dropdown">
        <button class="nav-link nav-toggle-btn" aria-expanded="false" aria-haspopup="true" id="services-btn">
          Services
          <svg class="chevron" width="12" height="12" viewBox="0 0 12 12" aria-hidden="true"><path d="M2 4l4 4 4-4" stroke="currentColor" stroke-width="1.5" fill="none" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </button>
        <div class="dropdown-menu" id="services-menu" role="menu">
          {links.map(l => (
            <a href={l.href} class:list={['dropdown-item', { active: pathname === l.href }]} role="menuitem">
              {l.label}
            </a>
          ))}
        </div>
      </div>

      <a href="/about" class:list={['nav-link', { active: pathname === '/about' }]}>About</a>
    </nav>

    <div class="header-actions">
      <a href="tel:8087954044" class="header-phone">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M6.62 10.79c1.44 2.83 3.76 5.14 6.59 6.59l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1-9.39 0-17-7.61-17-17 0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.25 1.02l-2.2 2.2z" fill="currentColor"/></svg>
        (808) 795-4044
      </a>
      <a href="/contact" class="btn btn-gold btn-sm">Free Estimate</a>
    </div>

    <button class="mobile-toggle" id="mobile-toggle" aria-label="Open menu" aria-expanded="false" aria-controls="primary-nav">
      <svg class="icon-menu" width="22" height="22" viewBox="0 0 22 22" fill="none" aria-hidden="true">
        <line x1="3" y1="6"  x2="19" y2="6"  stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
        <line x1="3" y1="11" x2="19" y2="11" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
        <line x1="3" y1="16" x2="19" y2="16" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
      </svg>
      <svg class="icon-close" width="22" height="22" viewBox="0 0 22 22" fill="none" aria-hidden="true">
        <line x1="4" y1="4" x2="18" y2="18" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
        <line x1="18" y1="4" x2="4" y2="18" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
      </svg>
    </button>
  </div>

  <!-- Mobile drawer -->
  <div class="mobile-menu" id="mobile-menu" aria-hidden="true">
    <div class="container">
      <p class="mobile-menu__label">Services</p>
      {links.map(l => (
        <a href={l.href} class="mobile-link">{l.label}</a>
      ))}
      <div class="mobile-divider"></div>
      <a href="/about"   class="mobile-link">About</a>
      <a href="/contact" class="mobile-link">Contact</a>
      <div class="mobile-divider"></div>
      <a href="tel:8087954044" class="mobile-phone">(808) 795-4044</a>
      <a href="/contact" class="btn btn-gold" style="display:block;text-align:center;margin-top:16px;">Get a Free Estimate</a>
    </div>
  </div>
</header>

<script>
  const toggle = document.getElementById('mobile-toggle')!;
  const menu   = document.getElementById('mobile-menu')!;
  const servicesBtn  = document.getElementById('services-btn')!;
  const servicesMenu = document.getElementById('services-menu')!;

  toggle.addEventListener('click', () => {
    const open = menu.getAttribute('aria-hidden') === 'true';
    menu.setAttribute('aria-hidden', String(!open));
    toggle.setAttribute('aria-expanded', String(open));
    document.body.classList.toggle('nav-open', open);
  });

  servicesBtn.addEventListener('click', (e) => {
    e.stopPropagation();
    const expanded = servicesBtn.getAttribute('aria-expanded') === 'true';
    servicesBtn.setAttribute('aria-expanded', String(!expanded));
    servicesMenu.classList.toggle('is-open', !expanded);
  });

  document.addEventListener('click', () => {
    servicesBtn.setAttribute('aria-expanded', 'false');
    servicesMenu.classList.remove('is-open');
  });
</script>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: var(--white);
    border-bottom: 1px solid var(--border);
  }

  .header-inner {
    display: flex;
    align-items: center;
    gap: 32px;
    height: 68px;
  }

  /* Logo */
  .site-logo {
    display: flex;
    align-items: center;
    gap: 10px;
    flex-shrink: 0;
    text-decoration: none;
  }
  .logo-mark {
    width: 36px; height: 36px;
    background: var(--gold);
    color: var(--white);
    border-radius: 4px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 700;
    font-size: 15px;
    letter-spacing: .02em;
    flex-shrink: 0;
  }
  .logo-text {
    font-weight: 700;
    font-size: 17px;
    color: var(--navy);
    line-height: 1;
  }
  .logo-llc {
    font-weight: 400;
    opacity: .6;
  }

  /* Primary nav */
  .primary-nav {
    display: flex;
    align-items: center;
    gap: 4px;
    margin-left: 8px;
  }

  .nav-link {
    display: flex;
    align-items: center;
    gap: 4px;
    padding: 8px 12px;
    font-size: 15px;
    font-weight: 500;
    color: var(--slate);
    border-radius: var(--r);
    cursor: pointer;
    background: none;
    border: none;
    font-family: var(--font);
    transition: color .15s, background .15s;
    text-decoration: none;
  }
  .nav-link:hover,
  .nav-link.active { color: var(--navy); background: rgba(0,0,0,.04); }

  /* Dropdown */
  .nav-dropdown { position: relative; }

  .chevron { transition: transform .15s; flex-shrink: 0; color: var(--slate); }
  [aria-expanded="true"] .chevron { transform: rotate(180deg); }

  .dropdown-menu {
    position: absolute;
    top: calc(100% + 8px);
    left: 0;
    background: var(--white);
    border: 1px solid var(--border);
    border-radius: var(--r);
    min-width: 220px;
    padding: 8px 0;
    display: none;
  }
  .dropdown-menu.is-open { display: block; }

  .dropdown-item {
    display: block;
    padding: 10px 16px;
    font-size: 15px;
    font-weight: 500;
    color: var(--slate);
    transition: background .12s, color .12s;
  }
  .dropdown-item:hover,
  .dropdown-item.active { background: rgba(0,0,0,.04); color: var(--navy); }

  /* Actions */
  .header-actions {
    margin-left: auto;
    display: flex;
    align-items: center;
    gap: 16px;
  }

  .header-phone {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 15px;
    font-weight: 600;
    color: var(--navy);
    white-space: nowrap;
  }

  /* Mobile */
  .mobile-toggle {
    display: none;
    background: none;
    border: none;
    cursor: pointer;
    padding: 4px;
    color: var(--navy);
    margin-left: auto;
  }
  .icon-close { display: none; }

  .mobile-menu {
    background: var(--white);
    border-top: 1px solid var(--border);
    padding: 20px 0 28px;
    display: none;
  }

  .mobile-menu__label {
    font-size: 12px;
    font-weight: 700;
    letter-spacing: .08em;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 6px;
    padding: 0;
  }

  .mobile-link {
    display: block;
    padding: 11px 0;
    font-size: 17px;
    font-weight: 500;
    color: var(--navy);
    border-bottom: 1px solid var(--border);
  }

  .mobile-phone {
    display: block;
    padding: 12px 0;
    font-size: 18px;
    font-weight: 700;
    color: var(--navy);
  }

  .mobile-divider { height: 16px; }

  @media (max-width: 800px) {
    .primary-nav, .header-phone { display: none; }
    .mobile-toggle { display: flex; align-items: center; justify-content: center; }
    .header-actions .btn { display: none; }
  }

  :global(body.nav-open) .icon-menu  { display: none; }
  :global(body.nav-open) .icon-close { display: block; }
  :global(body.nav-open) .mobile-menu { display: block; }
</style>
