---
const year = new Date().getFullYear();

const services = [
  { label: 'General Contracting',  href: '/services/general-contracting' },
  { label: 'Interior Remodeling',  href: '/services/interior-remodeling' },
  { label: 'Metal Fabrication',    href: '/services/metal-fabrication' },
];

const locations = [
  { label: 'Kihei',    href: '/locations/kihei' },
  { label: 'Wailea',   href: '/locations/wailea' },
  { label: 'Lahaina',  href: '/locations/lahaina' },
  { label: 'Wailuku',  href: '/locations/wailuku' },
  { label: 'Kahului',  href: '/locations/kahului' },
  { label: 'Paia',     href: '/locations/paia' },
];
---

<footer class="site-footer">
  <div class="container footer-grid">
    <div class="footer-brand">
      <div class="footer-logo">
        <span class="footer-logo-mark">GG</span>
        <span>Great General LLC</span>
      </div>
      <p>Licensed general contractor serving all of Maui, Hawaii. General contracting, interior remodeling, and custom metal fabrication.</p>
      <p class="footer-license">Hawaii DCCA B License</p>
      <div class="footer-contact">
        <a href="tel:8087954044">(808) 795-4044</a>
        <a href="mailto:noel@greatgeneral.com">noel@greatgeneral.com</a>
      </div>
    </div>

    <div class="footer-col">
      <h4>Services</h4>
      <ul>
        {services.map(s => <li><a href={s.href}>{s.label}</a></li>)}
      </ul>
    </div>

    <div class="footer-col">
      <h4>Service Areas</h4>
      <ul>
        {locations.map(l => <li><a href={l.href}>{l.label} Contractor</a></li>)}
      </ul>
      <p class="footer-also-serve">Also serving Makawao, Haiku &amp; surrounding Maui communities.</p>
    </div>

    <div class="footer-col footer-cta-col">
      <h4>Ready to start your project?</h4>
      <p>Free on-site estimates anywhere on Maui. Call or request an estimate online.</p>
      <a href="/contact" class="btn btn-gold btn-sm">Get a Free Estimate</a>
      <a href="tel:8087954044" class="footer-call-link">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M6.62 10.79c1.44 2.83 3.76 5.14 6.59 6.59l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1-9.39 0-17-7.61-17-17 0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.25 1.02l-2.2 2.2z"/></svg>
        (808) 795-4044
      </a>
    </div>
  </div>

  <div class="footer-bottom">
    <div class="container footer-bottom-inner">
      <p>&copy; {year} Great General LLC. All rights reserved. Maui, Hawaii.</p>
      <p><a href="/about">About</a> · <a href="/contact">Contact</a></p>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    background: var(--navy);
    color: rgba(255,255,255,.75);
    padding-top: 64px;
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr 1.5fr;
    gap: 48px;
    padding-bottom: 48px;
    border-bottom: 1px solid rgba(255,255,255,.1);
  }

  /* Brand column */
  .footer-logo {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 16px;
  }
  .footer-logo-mark {
    width: 34px; height: 34px;
    background: var(--gold);
    color: var(--navy);
    border-radius: 4px;
    display: flex; align-items: center; justify-content: center;
    font-weight: 700; font-size: 14px;
    flex-shrink: 0;
  }
  .footer-logo span:last-child {
    font-weight: 700;
    font-size: 16px;
    color: var(--white);
  }

  .footer-brand p {
    font-size: 14px;
    color: rgba(255,255,255,.65);
    margin-bottom: 10px;
  }

  .footer-license {
    display: inline-block;
    font-size: 12px !important;
    font-weight: 600;
    letter-spacing: .06em;
    text-transform: uppercase;
    color: var(--gold) !important;
    margin-bottom: 16px !important;
    padding: 4px 10px;
    border: 1px solid rgba(37,99,235,.4);
    border-radius: var(--r);
  }

  .footer-contact {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }
  .footer-contact a {
    font-size: 15px;
    font-weight: 600;
    color: var(--white);
    text-decoration: none;
  }
  .footer-contact a:hover { color: var(--gold); }

  /* Nav columns */
  .footer-col h4 {
    font-size: 13px;
    font-weight: 700;
    letter-spacing: .07em;
    text-transform: uppercase;
    color: var(--white);
    margin-bottom: 16px;
  }

  .footer-col ul { list-style: none; }
  .footer-col ul li { margin-bottom: 10px; }
  .footer-col ul a {
    font-size: 14px;
    color: rgba(255,255,255,.65);
    transition: color .15s;
  }
  .footer-col ul a:hover { color: var(--white); }

  .footer-also-serve {
    font-size: 13px;
    color: rgba(255,255,255,.45);
    margin-top: 12px;
    margin-bottom: 0;
  }

  /* CTA column */
  .footer-cta-col h4 {
    font-size: 13px;
    font-weight: 700;
    letter-spacing: .07em;
    text-transform: uppercase;
    color: var(--white);
    margin-bottom: 12px;
  }
  .footer-cta-col p {
    font-size: 14px;
    color: rgba(255,255,255,.65);
    margin-bottom: 18px;
  }
  .footer-call-link {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 15px;
    font-weight: 600;
    color: rgba(255,255,255,.75);
    margin-top: 12px;
  }
  .footer-call-link:hover { color: var(--white); }

  /* Bottom bar */
  .footer-bottom {
    padding: 20px 0;
  }
  .footer-bottom-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 12px;
  }
  .footer-bottom p {
    font-size: 13px;
    color: rgba(255,255,255,.45);
    margin: 0;
  }
  .footer-bottom a {
    color: rgba(255,255,255,.45);
    text-decoration: none;
  }
  .footer-bottom a:hover { color: rgba(255,255,255,.75); }

  @media (max-width: 960px) {
    .footer-grid { grid-template-columns: 1fr 1fr; gap: 36px; }
    .footer-brand { grid-column: 1 / -1; }
  }

  @media (max-width: 560px) {
    .footer-grid { grid-template-columns: 1fr; }
    .footer-brand { grid-column: auto; }
    .footer-bottom-inner { flex-direction: column; align-items: flex-start; }
  }
</style>
