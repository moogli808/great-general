---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Project Gallery | Our Work in Maui | Great General LLC"
  description="Photos of completed projects by Great General LLC — custom metal fabrication, gates, railings, quonset hut construction, and interior remodeling across Maui, Hawaii."
  canonical="/gallery"
>

<div class="page-hero">
  <div class="container">
    <nav class="breadcrumb" aria-label="Breadcrumb">
      <a href="/">Home</a><span>›</span>
      Gallery
    </nav>
    <span class="label">Completed Projects · Maui, Hawaii</span>
    <h1>Our Work in Maui</h1>
    <p>Photos from completed projects across Maui — custom metalwork, agricultural structures, and full interior remodels. All work performed by our licensed crew under Noel's direct supervision.</p>
  </div>
</div>

<section class="section section--white">
  <div class="container">

    <div class="gallery-section-header">
      <span class="label">Metal Fabrication &amp; Structural</span>
      <h2>Custom Metalwork &amp; Construction</h2>
      <p>Custom gates, railings, fencing, roofing, and large-span structures built for Maui's coastal environment.</p>
    </div>

    <div class="gallery-grid">
      <figure class="photo-card">
        <img
          src="/images/metal-fab-hero.jpg"
          alt="Custom stainless steel pool railings Maui by Great General LLC — oceanfront luxury property Wailea"
          loading="lazy"
          width="800"
          height="600"
        />
        <figcaption>Custom Pool Railings · Oceanfront luxury property, Wailea</figcaption>
      </figure>
      <figure class="photo-card">
        <img
          src="/images/metal-fab-railing-1.jpg"
          alt="Pool railing installation Maui oceanfront property by Great General LLC"
          loading="lazy"
          width="800"
          height="600"
        />
        <figcaption>Pool Railing Installation · Coastal property, Maui</figcaption>
      </figure>
