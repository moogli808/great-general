        <img
          src="/images/metal-fab-railing-2.jpg"
          alt="Great General LLC owner Noel on site during railing installation at luxury Wailea property"
          loading="lazy"
          width="800"
          height="600"
        />
        <figcaption>On Site · Noel overseeing railing installation, Wailea</figcaption>
      </figure>
      <figure class="photo-card">
        <img
