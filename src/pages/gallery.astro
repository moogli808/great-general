<section class="cta-banner">
  <div class="container">
    <span class="label" style="color:#93C5FD;">Ready to Start?</span>
    <h2>Let's Talk About Your Project</h2>
    <p>Free on-site estimates anywhere on Maui. Call Noel directly or submit a request online.</p>
    <div class="btn-group">
      <a href="/contact" class="btn btn-gold btn-lg">Request a Free Estimate</a>
      <a href="tel:8087954044" class="btn btn-outline btn-lg">Call (808) 795-4044</a>
    </div>
  </div>
</section>

</BaseLayout>

<style>
  .gallery-section-header {
    margin-bottom: 40px;
  }
  .gallery-section-header h2 { margin-bottom: 10px; }
  .gallery-section-header p  { font-size: 16px; color: var(--slate); max-width: 640px; }

  .gallery-section-2 {
    padding-top: 0;
    border-top: 1px solid var(--border);
  }

  .gallery-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }

  @media (max-width: 960px) {
    .gallery-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 560px) {
    .gallery-grid { grid-template-columns: 1fr; }
  }
</style>
