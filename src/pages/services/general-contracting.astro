  .sidebar-phone {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 15px;
    font-weight: 700;
    color: var(--navy);
    margin-top: 12px;
  }

  .sidebar-links { list-style: none; }
  .sidebar-links li { margin-bottom: 10px; }
  .sidebar-links a { font-size: 15px; font-weight: 600; color: var(--navy); }
  .sidebar-links a:hover { color: var(--gold); }

  /* ── Scope highlight cards ── */
  .scope-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
    margin: 24px 0 36px;
  }
  .scope-card {
    display: flex;
    gap: 14px;
    align-items: flex-start;
    background: var(--bg, #F0F4F8);
    border: 1px solid var(--border, #e2e8f0);
    border-radius: 8px;
    padding: 18px 20px;
  }
  .scope-card__icon {
    font-size: 24px;
    line-height: 1;
    flex-shrink: 0;
    margin-top: 2px;
  }
  .scope-card h4 {
    font-size: 15px;
    font-weight: 700;
    color: var(--navy);
    margin: 0 0 6px;
  }
  .scope-card p {
    font-size: 14px;
    color: var(--slate);
    margin: 0;
    line-height: 1.55;
  }

  .project-hero-fig {
    margin: 0 0 56px;
  }
  .project-hero-fig img {
    display: block;
    width: 100%;
    max-width: 100%;
    height: 460px;
    object-fit: cover;
    border-radius: var(--r);
